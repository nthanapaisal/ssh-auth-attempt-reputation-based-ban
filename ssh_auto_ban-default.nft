table inet ssh_auto_bans {

    set banned_v4 {
        type ipv4_addr
        flags timeout
    }

    set banned_v6 {
        type ipv6_addr
        flags timeout
    }

    chain input {
        type filter hook input priority 0;
        policy accept;

        ip saddr @banned_v4 log prefix "SSH autoban: " drop
        ip6 saddr @banned_v6 log prefix "SSH autoban: " drop
    }

}
